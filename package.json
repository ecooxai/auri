{
  "name": "auri",
  "version": "0.84.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "node --test",
    "test:rust": "node scripts/rust-check.mjs",
    "dev": "node scripts/native-dev.mjs",
    "build": "node scripts/native-build.mjs",
    "check": "npm test && npm run test:rust && npm run build",
    "tauri:dev": "cargo tauri dev",
    "tauri:build": "node scripts/tauri-build.mjs",
    "release:linux": "node scripts/package-linux-release.mjs",
    "cli:build": "cargo build --manifest-path src-tauri/Cargo.toml --release --features cli-bin --bin auri",
    "cli:install": "cargo install --path src-tauri --bin auri --features cli-bin --force",
    "native:watch": "node scripts/native-dev.mjs",
    "dev:web": "node scripts/dev.mjs",
    "build:web": "node scripts/build.mjs",
    "app": "node scripts/app.mjs"
  },
  "dependencies": {
    "@codemirror/state": "^6.7.0",
    "@google/genai": "^2.10.0",
    "codemirror": "^6.0.2",
    "esbuild": "^0.28.1",
    "three": "^0.180.0"
  }
}
